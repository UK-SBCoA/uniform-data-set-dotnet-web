        <label asp-for="A1a.EXPSTRS"> <span class="counter"> </span> @(Model.Visit.PACKET == PacketKind.F ?
            "When you have had day-to-day experiences like those in questions 31 to 36, would you say they have been verystressful, moderately stressful, or not stressful" : Html.DisplayNameFor(model => model.A1a.EXPSTRS))</label>

        <div class="mt-4 sm:col-span-2 sm:mt-0">
            <div class="max-w-lg">
                <p class="text-sm text-gray-500" asp-description-for="@Model.A1a.EXPSTRS"></p>
                <radio-button-group id="A1_EXPSTRS" for="A1a.EXPSTRS" items="Model.StressfulToNotStressfulItems"></radio-button-group>
                <span class="mt-2 text-sm text-red-600" asp-validation-for="@Model.A1a.EXPSTRS"></span>
                <submission-error location="EXPSTRS" errors="Model.BaseForm.UnresolvedErrors" />
            </div>
        </div>
    </div>
</div>

@{
    ViewData["IsA1a"] = "true";

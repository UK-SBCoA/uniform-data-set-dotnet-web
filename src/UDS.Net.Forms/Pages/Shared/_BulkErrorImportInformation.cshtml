@using System.Text.Json

@{
    ViewData["Title"] = "Packets";

    string importStatus = string.Empty;
    string[] importDetails = Array.Empty<string>();
    string[] errorDetails = Array.Empty<string>();
    string importDetailsStyle = string.Empty;

    if (TempData["importStatus"] != null)
    {
        importStatus = TempData["importStatus"].ToString();
    }

    if (TempData["importDetails"] != null)
    {
        importDetails = JsonSerializer.Deserialize<string[]>(TempData["importDetails"].ToString());
    }

    if (TempData["errorDetails"] != null)
    {
        errorDetails = JsonSerializer.Deserialize<string[]>(TempData["errorDetails"].ToString());
    }

    if (TempData["importStatus"] != null)
    {
        importDetailsStyle = TempData["importStatus"]?.ToString() == "success" ? "bg-green-100 px-3 py-1 text-sm font-medium text-green-800" : "bg-red-100 px-3 py-1 text-sm font-medium text-red-800";
    }
}

@if (!string.IsNullOrEmpty(importStatus) && importDetails?.Length > 0)
{
    <div class="col text-center">
        <div class="@importDetailsStyle border rounded-lg shadow-sm space-y-3">
            <div>
                Error import @importStatus
            </div>
            <div>
                <ul>
                    @foreach (var details in importDetails)
                    {
                        <li>@details</li>
                    }
                </ul>
            </div>
            <div>
                @if (importStatus == "fail" && errorDetails?.Length > 0)
                {
                    <ul>
                        @foreach (var error in errorDetails)
                        {
                            <li>@error</li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
}